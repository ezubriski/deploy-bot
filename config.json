{
  "github": {
    "org": "myorg",
    "repo": "gitops-repo"
  },
  "authorization": [
    {"type": "github_teams", "value": ["deployers"]}
  ],
  "slack": {
    "deploy_channel": "prod-deployments"
  },
  "deployment": {
    "stale_duration": "2h",
    "merge_method": "squash",
    "lock_ttl": "5m"
  },
  "aws": {
    "ecr_region": "us-east-1",
    "audit_bucket": "my-audit-logs",
    "audit_region": "us-east-1"
  },
  "apps": [
    {
      "app": "myapp",
      "kustomize_path": "apps/myapp/kustomization.yaml",
      "ecr_repo": "123456789.dkr.ecr.us-east-1.amazonaws.com/myapp",
      "tag_pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    }
  ]
}
