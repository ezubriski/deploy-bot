{
  "github": {
    "org": "myorg",
    "repo": "gitops-repo",
    "deployer_team": "deployers",
    "approver_team": "senior-engineers"
  },
  "slack": {
    "deploy_channel": "prod-deployments"
  },
  "deployment": {
    "stale_duration": "2h",
    "merge_method": "squash",
    "lock_ttl": "5m"
  },
  "aws": {
    "ecr_role_arn": "arn:aws:iam::ECR_ACCOUNT_ID:role/deploy-bot-ecr-reader",
    "ecr_region": "us-east-1",
    "audit_role_arn": "arn:aws:iam::AUDIT_ACCOUNT_ID:role/deploy-bot-audit-writer",
    "audit_bucket": "my-audit-logs",
    "audit_region": "us-east-1"
  },
  "apps": [
    {
      "app": "myapp",
      "kustomize_path": "apps/myapp/kustomization.yaml",
      "ecr_repo": "123456789.dkr.ecr.us-east-1.amazonaws.com/myapp",
      "tag_pattern": "^v[0-9]+\\.[0-9]+\\.[0-9]+$"
    }
  ]
}
