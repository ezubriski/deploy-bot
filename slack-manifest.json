{
  "_metadata": {
    "major_version": 1,
    "minor_version": 1
  },
  "display_information": {
    "name": "deploy-bot",
    "description": "Approval-gated Kubernetes deployments via GitOps"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "deploy-bot",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/deploy",
        "description": "Request, approve, and manage deployments",
        "usage_hint": "[app] [status | history [app] | tags <app> | cancel <pr> | nudge <pr> | rollback <app>]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "commands",
        "chat:write",
        "users:read",
        "users:read.email",
        "im:write"
      ]
    }
  },
  "settings": {
    "interactivity": {
      "is_enabled": true
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
