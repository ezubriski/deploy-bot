# deploy-bot setup variables
#
# Copy this file to setup.env and fill in your values. Source it before
# running any setup commands:
#
#   cp setup.env.example setup.env
#   # edit setup.env with your values
#   source setup.env

# --- GitHub ---
export GITHUB_ORG=your-org
export GITHUB_REPO=your-gitops-repo

# Primary bot token (fine-grained PAT scoped to $GITHUB_REPO)
# Create at: https://github.com/settings/personal-access-tokens/new
export DEPLOY_BOT_TOKEN=github_pat_...

# Scanner token (optional, fine-grained PAT scoped to all repos)
# Only needed if using repo-sourced app discovery
# export DEPLOY_BOT_SCANNER_TOKEN=github_pat_...

# --- Slack ---
# Create the Slack app from slack-manifest.json, then grab these:
export SLACK_BOT_TOKEN=xoxb-...
export SLACK_APP_TOKEN=xapp-...
export SLACK_DEPLOY_CHANNEL=C0123456789

# --- AWS ---
export AWS_REGION=us-east-1
export DEPLOY_BOT_SECRET_NAME=deploy-bot/secrets
export AUDIT_BUCKET=my-audit-logs

# --- Redis ---
export REDIS_ADDR=your-redis:6379
